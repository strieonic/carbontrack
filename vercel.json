{
  "rewrites": [
    { "source": "/survey", "destination": "/pages/survey.html" },
    { "source": "/dashboard", "destination": "/pages/dashboard.html" },
    { "source": "/comparison", "destination": "/pages/comparison.html" },
    { "source": "/suggestions", "destination": "/pages/suggestions.html" },
    { "source": "/impact", "destination": "/pages/impact.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
